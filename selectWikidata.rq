# Esta consulta retorna trabalhos associados ao NeuroMat (Q18477654)
# por meio da propriedade "parte de" (P361). 
# Para cada trabalho, recupera o DOI (P356) e, se disponível, a data de publicação (P577).
# Também é recuperado o QID do item.
# Os resultados são ordenados da data mais recente para a mais antiga
# e incluem os rótulos dos itens no idioma automático ou em inglês.


SELECT (STRAFTER(STR(?work), "http://www.wikidata.org/entity/") AS ?QID) ?workLabel ?doi ?publicationDate WHERE {
  ?work wdt:P361 wd:Q18477654.      # P361 = parte de, Q18477654 = NeuroMat
  ?work wdt:P356 ?doi.              # P356 = DOI
  OPTIONAL { ?work wdt:P577 ?publicationDate. }  # P577 = data de publicação

  SERVICE wikibase:label { bd:serviceParam wikibase:language "[AUTO_LANGUAGE],en". }
}
ORDER BY DESC(?publicationDate)
LIMIT 600
